import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from datetime import datetime
from collections import defaultdict
import re

# Catalogy定数（全7領域統一）
PHI = (1 + np.sqrt(5)) / 2  # 黄金比 1.6180339887
LEGAL_CRITICAL_DENSITY = np.log(14.134725 * PHI**2)  # 法解釈臨界密度
LEGAL_PRECEDENT_WEIGHT = PHI**3  # 判例影響力増強 4.236倍

class SuzukiLegalCatalogy:
    def __init__(self):
        self.phi = PHI
        self.legal_density_threshold = LEGAL_CRITICAL_DENSITY
        self.precedent_weight = LEGAL_PRECEDENT_WEIGHT
        
    def parse_legal_text(self, text):
        """条文解析：Catalogy情報密度抽出"""
        # 法的概念の複素空間表現
        keywords = {
            '要件': 1.0, '効果': 0.9, '違法': -1.0, '故意': 1.2,
            '過失': 0.8, '損害': 1.1, '因果関係': 1.3, '判例': 1.5
        }
        
        density_components = []
        for keyword, weight in keywords.items():
            count = len(re.findall(keyword, text))
            density_components.append(count * weight * self.phi)
        
        # 法的複素空間 s = Re(要件効果) + iIm(違法性)
        legal_complex = complex(np.mean(density_components[:4]), 
                              np.mean(density_components[4:]))
        density = np.abs(np.imag(legal_complex)) * np.log(self.phi * np.abs(legal_complex))
        return density
    
    def catalogy_judgment_phase(self, density, precedent_support=0.5):
        """Catalogy判決相転移：法的結論物理強制"""
        weighted_density = density * (1 + precedent_support * self.precedent_weight)
        
        phases = {
            weighted_density > self.legal_density_threshold * 1.5: "原告勝訴確定",
            weighted_density > self.legal_density_threshold: "原告有利",
            weighted_density > self.legal_density_threshold * 0.7: "争点法理適用",
            0.3 < weighted_density <= self.legal_density_threshold * 0.7: "被告有利", 
            weighted_density <= 0.3: "被告勝訴確定"
        }
        return next(v for k, v in phases.items() if k)
    
    def phi_contract_clause_analysis(self, contract_text):
        """ϕ契約条項解析：黄金比リスク配分最適化"""
        clauses = re.split(r'(第\d+条|附則)', contract_text)
        
        risk_profile = []
        for clause in clauses:
            density = self.parse_legal_text(clause)
            risk = np.tanh(density - self.legal_density_threshold)
            risk_profile.append({
                'clause': clause[:50] + '...',
                'density': density,
                'risk_score': risk,
                'phi_risk': risk * self.phi
            })
        
        total_risk = np.mean([r['phi_risk'] for r in risk_profile])
        return pd.DataFrame(risk_profile), total_risk
    
    def precedent_phi_amplification(self, case_history, current_case_density):
        """判例ϕ増幅：過去判例の黄金比影響力"""
        amplified_density = current_case_density
        for precedent in case_history:
            similarity = 1 / (1 + np.abs(precedent['density'] - current_case_density))
            amplified_density += similarity * precedent['weight'] * self.phi
        
        return amplified_density
    
    def legal_risk_phi_portfolio(self, cases):
        """ϕ最適訴訟ポートフォリオ：黄金比勝訴率最大化"""
        weights = np.array([1/self.phi**i for i in range(len(cases))])
        weights = weights / weights.sum()
        
        expected_wins = np.dot(weights, [case['win_prob'] for case in cases])
        return weights, expected_wins
    
    def complete_legal_analysis(self, case_text, precedents=[], contract=None):
        """完全法律解析：Catalogy7領域統合"""
        # 1. 事案Catalogy密度
        density = self.parse_legal_text(case_text)
        
        # 2. 判例ϕ増幅
        amplified_density = self.precedent_phi_amplification(precedents, density)
        
        # 3. Catalogy相転移（最終判決予測）
        judgment = self.catalogy_judgment_phase(amplified_density)
        
        # 4. 勝訴確率ϕ計算
        win_prob = min(0.99, 1 - np.exp(-(amplified_density - self.legal_density_threshold)))
        
        result = {
            'case_density': density,
            'phi_amplified_density': amplified_density,
            'judgment_phase': judgment,
            'win_probability': win_prob,
            'phi_confidence': win_prob * self.phi,
            'legal_certainty': np.tanh(amplified_density / self.legal_density_threshold)
        }
        
        if contract:
            contract_df, total_risk = self.phi_contract_clause_analysis(contract)
            result['contract_risk'] = total_risk
            result['contract_df'] = contract_df
        
        return result
    
    def batch_legal_portfolio(self, case_library):
        """訴訟ポートフォリオ完全最適化"""
        results = []
        for case_id, case_data in case_library.items():
            analysis = self.complete_legal_analysis(
                case_data['text'], 
                case_data.get('precedents', []),
                case_data.get('contract')
            )
            analysis['case_id'] = case_id
            results.append(analysis)
        
        df = pd.DataFrame(results)
        df['phi_priority'] = df['phi_confidence'].rank(ascending=False)
        return df.sort_values('phi_priority')
    
    def plot_legal_catalogy(self, df):
        """法律Catalogy可視化"""
        fig, ((ax1, ax2), (ax3, ax4)) = plt.subplots(2, 2, figsize=(16, 12))
        
        # 1. Catalogy判決相転移
        colors = {'原告勝訴確定': 'darkgreen', '原告有利': 'green', 
                 '争点法理適用': 'orange', '被告有利': 'red', '被告勝訴確定': 'darkred'}
        for phase, color in colors.items():
            mask = df['judgment_phase'] == phase
            ax1.scatter(df.loc[mask, 'case_density'], df.loc[mask, 'win_probability'], 
                       c=color, label=phase, s=100, alpha=0.8)
        
        ax1.axvline(x=self.legal_density_threshold, color='gold', ls='--', lw=2, 
                   label=f'法解釈臨界密度 ϕ²*log(14.13)')
        ax1.set_xlabel('法的情報密度')
        ax1.set_ylabel('勝訴確率')
        ax1.legend(bbox_to_anchor=(1.05, 1), loc='upper left')
        ax1.set_title('ϕ-Catalogy: 判決相転移')
        
        # 2. ϕ判例増幅効果
        ax2.scatter(df['case_density'], df['phi_amplified_density'], alpha=0.6)
        ax2.plot([0, max(df['case_density'])], [0, max(df['case_density'])], 'k--', alpha=0.5)
        ax2.set_xlabel('原密度')
        ax2.set_ylabel('ϕ増幅密度')
        ax2.set_title(f'判例黄金比増幅 (ϕ³={self.precedent_weight:.2f}x)')
        
        # 3. 勝訴確率分布
        ax3.hist(df['win_probability'], bins=30, alpha=0.7, color='skyblue', edgecolor='navy')
        ax3.axvline(x=0.9, color='gold', ls='--', lw=3, label='90%信頼区間')
        ax3.set_xlabel('勝訴確率')
        ax3.set_ylabel('事案数')
        ax3.legend()
        ax3.set_title('Catalogy勝訴確率分布')
        
        # 4. ϕ最適訴訟ポートフォリオ
        portfolio_weights = [1/self.phi**i for i in range(7)]
        ax4.pie(portfolio_weights, labels=[f'Case{i+1}' for i in range(7)], 
                autopct='%1.1f%%', startangle=90)
        ax4.set_title(f'ϕ最適訴訟配分 (期待勝訴率: {np.mean(df.win_probability):.1%})')
        
        plt.tight_layout()
        plt.show()

