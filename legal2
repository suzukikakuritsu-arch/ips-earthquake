        patent_hash = hashlib.sha256(patent_text.encode()).hexdigest()
        
        # ϕハミング距離計算
        distance = sum(c1 != c2 for c1, c2 in zip(code_hash[:64], patent_hash[:64]))
        phi_distance = distance / 64 * np.log(self.phi**8)
        
        # Catalogy侵害密度
        s = complex(np.mean([ord(c) for c in code_text[:100]]), 
                   np.mean([ord(c) for c in patent_text[:100]]))
        density = np.abs(np.imag(s)) * np.log(self.phi * np.abs(s))
        
        infringement_prob = 1 - np.exp(-phi_distance)
        return {
            'phi_distance': phi_distance,
            'infringement_density': density,
            'infringement_probability': infringement_prob,
            'infringement_threshold': phi_distance > 0.3
        }
    
