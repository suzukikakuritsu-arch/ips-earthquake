    def egov_law_fetcher(self, law_number=None, keyword=None):
        """e-Gov法令API自動取得（特許法・著作権法）"""
        base_url = "https://elaws.e-gov.go.jp/api/1.0/law"
        params = {'lawNumber': law_number} if law_number else {'keyword': keyword}
        
        try:
            resp = requests.get(base_url, params=params, timeout=5)
            laws = resp.json()
            return laws
        except:
            # フォールバック：主要法令内蔵
            return self.builtin_ip_laws()
    
