                )
                litigation['patent_id'] = patent_id
                litigation['code_id'] = code_id
                results.append(litigation)
        
        df = pd.DataFrame(results)
        df['phi_priority'] = df['phi_certainty'].rank(ascending=False)
        return df.sort_values('phi_priority').head(20)
    
