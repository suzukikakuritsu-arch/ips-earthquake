        }
        
        return {
            'novelty_score': novelty_score,
            'progressiveness': progressiveness,
            'validity_phase': next(v for k, v in validity_phases.items() if k),
            'patent_phi_score': novelty_score * progressiveness * self.phi**2
        }
    
    def complete_ip_litigation(self, code_sample, patent_text, infringer_data):
        """完全知的財産訴訟解析：Catalogy8領域統合"""
