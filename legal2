            infringer_data['revenue'], fingerprint['infringement_probability']
        )
        
        # 4. Catalogy最終判断
        total_density = fingerprint['infringement_density'] * law_density * self.phi
        judgment = "侵害確定・即時支払命令" if total_density > self.ip_crit_density else "非侵害"
        
        return {
            'infringement': fingerprint,
            'law_density': law_density,
            'license_fee': license_fee,
            'total_density': total_density,
            'final_judgment': judgment,
            'recovery_amount': float(license_fee['phi_fee']),
            'phi_certainty': min(0.995, 1 - np.exp(-(total_density - self.ip_crit_density)))
        }
    
    def ip_portfolio_analysis(self, patent_library, code_library):
        """知的財産ポートフォリオ完全解析"""
        results = []
        for patent_id, patent_data in patent_library.items():
            for code_id, code_data in code_library.items():
                litigation = self.complete_ip_litigation(
