    def patent_validity_catalogy(self, invention_text, prior_art):
        """特許有効性Catalogy：新規性・進歩性自動判定"""
        inv_density = self.parse_legal_text(invention_text)
        prior_density = np.mean([self.parse_legal_text(pa) for pa in prior_art])
        
        novelty_score = np.tanh((inv_density - prior_density) * self.phi)
        progressiveness = 1 / (1 + np.exp(-(inv_density - prior_density * 1.2)))
        
        validity_phases = {
            novelty_score > 0.8 and progressiveness > 0.9: "特許付与確定",
            novelty_score > 0.6: "進歩性あり",
            novelty_score > 0.3: "新規性微妙",
