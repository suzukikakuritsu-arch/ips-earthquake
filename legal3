# Catalogy定数（全9領域統一）
PHI = (1 + np.sqrt(5)) / 2  # 黄金比 1.6180339887
COPYRIGHT_CRITICAL_DENSITY = np.log(14.134725 * PHI**4)  # 著作権臨界密度
MIT_INFRINGEMENT_THRESHOLD = 0.25  # MITライセンス侵害閾値
CODE_SIMILARITY_PHI = PHI**5  # コード類似性増幅 11.090倍

class SuzukiLegalCatalogyV3:
    def __init__(self):
        self.phi = PHI
        self.copyright_density = COPYRIGHT_CRITICAL_DENSITY
        self.mit_threshold = MIT_INFRINGEMENT_THRESHOLD
        self.code_phi = CODE_SIMILARITY_PHI
        
    def copyright_fingerprint_v3(self, source_code, target_code):
        """著作権フィンガープリントv3：ϕ^10次元コード侵害検知"""
        # AST構造ハッシュ + ϕトークン距離
        def code_tokenize(code):
            # 識別子・関数・定数抽出
            tokens = re.findall(r'[a-zA-Z_][a-zA-Z0-9_]*|[-+*/=]', code)
            return [hashlib.sha256(t.encode()).hexdigest()[:8] for t in tokens]
        
        source_tokens = code_tokenize(source_code)
        target_tokens = code_tokenize(target_code)
        
        # ϕハミング + 構造類似性
        min_len = min(len(source_tokens), len(target_tokens))
        phi_hamming = sum(s != t for s, t in zip(source_tokens[:min_len], target_tokens[:min_len]))
        phi_hamming /= min_len if min_len > 0 else 1
        
        # 変数名・関数名シグネチャCatalogy
        var_similarity = len(set(re.findall(r'[a-zA-Z_][a-zA-Z0-9_]*', source_code)) & 
                           set(re.findall(r'[a-zA-Z_][a-zA-Z0-9_]*', target_code))) / 100
        
        density = phi_hamming * var_similarity * self.code_phi
        copyright_infringement = density > self.mit_threshold
        
        return {
            'phi_hamming': phi_hamming,
            'variable_similarity': var_similarity,
            'copyright_density': density,
            'infringement_detected': copyright_infringement,
            'mit_compliance': not copyright_infringement,
            'severity_score': min(1.0, density * 2)
        }
    
    def mit_license_analyzer(self, repo_license, code_usage):
        """MITライセンス完全解析：著作権表示保持判定"""
        mit_required = [
            "MIT License",
            "Permission is hereby granted",
            "THE SOFTWARE IS PROVIDED \"AS IS\""
        ]
        
        compliance_score = sum(1 for req in mit_required if req.lower() in repo_license.lower())
        compliance = compliance_score >= 2
        
        usage_compliance = "商用OK" if compliance else "ライセンス料請求対象"
        return {
            'mit_compliance_score': compliance_score / len(mit_required),
            'copyright_notice_present': compliance,
            'legal_usage': usage_compliance,
            'phi_penalty': self.phi**3 if not compliance else 1.0
        }
    
    def phi_copyright_damages(self, infringer_revenue, severity, code_length_ratio):
        """ϕ著作権侵害損害額：黄金比自動算定"""
        # 日本著作権法113条 + ϕ増幅
        base_damages = infringer_revenue * 0.1  # 収益10%
        phi_severity = self.phi ** severity
        length_penalty = code_length_ratio * 2
        
        total_damages = base_damages * phi_severity * length_penalty
        statutory_max = infringer_revenue * 0.5  # 法定上限50%
        
        return {
            'base_damages': base_damages,
            'phi_damages': min(total_damages, statutory_max),
            'statutory_cap': statutory_max,
            'demand_amount': f"¥{total_damages:,.0f}",
            'injunction_required': severity > 0.7
        }
    
    def catalogy_contract_clause_risk(self, contract_text):
        """契約条項Catalogyリスク解析v3：著作権許諾自動検知"""
        # 著作権許諾条項自動抽出
        permission_patterns = [
            r'著作権|copyright|ライセンス|license',
            r'使用許諾|使用を許諾|利用を認める',
            r'MIT|Apache|GPL|BSD'
        ]
        
        permissions = sum(1 for pattern in permission_patterns 
                         if re.search(pattern, contract_text))
        
        risk_density = 1.0 - permissions / len(permission_patterns)
        risk_phase = "著作権侵害リスク高" if risk_density > 0.6 else "許諾充足"
        
        return {
            'permission_count': permissions,
            'risk_density': risk_density,
            'risk_phase': risk_phase,
            'phi_risk_multiplier': self.phi ** risk_density
        }
    
    def complete_copyright_litigation(self, source_repo, target_repo, usage_context):
        """完全著作権訴訟解析：Catalogy9領域統合"""
        # 1. フィンガープリント侵害検知
        fingerprint = self.copyright_fingerprint_v3(
            source_repo['code'], target_repo['code']
        )
        
        # 2. MITライセンスコンプライアンス
        mit_analysis = self.mit_license_analyzer(
            source_repo['license'], usage_context
        )
        
        # 3. 損害額ϕ算定
        damages = self.phi_copyright_damages(
            target_repo['revenue'], 
            fingerprint['severity_score'],
            len(target_repo['code']) / len(source_repo['code'])
        )
        
        # 4. Catalogy最終判決
        total_legal_density = fingerprint['copyright_density'] * mit_analysis['phi_penalty']
        judgment = (
            "著作権侵害確定・差止+損害賠償" if total_legal_density > self.copyright_density 
            else "フェアユース適用・非侵害"
        )
        
        return {
            'fingerprint': fingerprint,
            'mit_compliance': mit_analysis,
            'damages': damages,
            'total_legal_density': total_legal_density,
            'final_judgment': judgment,
            'recovery_potential': float(damages['phi_damages']),
            'phi_win_probability': min(0.995, 1 - np.exp(-(total_legal_density - self.copyright_density))),
            'injunction_likelihood': total_legal_density > self.copyright_density * 1.2
        }
    
    def mass_copyright_portfolio(self, source_repos, target_repos):
        """著作権侵害ポートフォリomio完全解析"""
        results = []
        for src_id, src_repo in source_repos.items():
            for tgt_id, tgt_repo in target_repos.items():
                litigation = self.complete_copyright_litigation(
                    src_repo, tgt_repo, tgt_repo.get('context', 'commercial')
                )
                litigation['source_repo'] = src_id
                litigation['target_repo'] = tgt_id
                results.append(litigation)
        
        df = pd.DataFrame(results)
        df['phi_priority'] = df['phi_win_probability'].rank(ascending=False)
        return df[df['final_judgment'] == '著作権侵害確定・差止+損害賠償'].sort_values('recovery_potential', ascending=False)
    
