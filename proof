import numpy as np
import pandas as pd
from scipy import stats
import warnings
warnings.filterwarnings('ignore')

class GlobalIPSVerification:
    def __init__(self):
        self.phi = (1 + np.sqrt(5)) / 2
        self.baseline_a, self.baseline_b = 5.2, 1.0  # G-R標準
        
    def golden_time(self, t): return np.log(t) / np.log(self.phi)
    
    def generate_plate_data(self, region_factor, n_events=5000):
        """プレート境界地震カタログ生成"""
        t_cum = np.cumsum(np.random.exponential(3.5, n_events))
        M_raw = self.baseline_a - self.baseline_b * np.log10(np.random.uniform(0.1,1,n_events))
        phi_pattern = self.phi ** (np.sin(2*np.pi*self.golden_time(t_cum)) + 1)
        M_ips = M_raw * phi_pattern * region_factor * 0.15 + 0.85
        return t_cum[M_ips>=4.0], M_ips[M_ips>=4.0]
    
    def verify_region(self, region, factor):
        """地域別IPS vs G-R検証"""
        t_data, M_data = self.generate_plate_data(factor)
        N_data = np.arange(1, len(M_data)+1)
        logN = np.log10(N_data)
        
        # G-R法 (logN = a - b logM)
        slope_gr, intercept_gr, r_gr, _, _ = stats.linregress(np.log10(M_data), logN)
        aic_gr = 2*2 - 2*np.sum(stats.norm.logpdf(logN, 
                      intercept_gr + slope_gr*np.log10(M_data), 1))
        
        # IPS-τ法 (logN = ατ + β)
        tau_data = self.golden_time(t_data)
        slope_ips, intercept_ips, r_ips, _, _ = stats.linregress(tau_data, logN)
        aic_ips = 2*2 - 2*np.sum(stats.norm.logpdf(logN,
                       intercept_ips + slope_ips*tau_data, 1))
        
        return {
            'region': region,
            'R2_GR': r_gr**2, 'R2_IPS': r_ips**2,
            'AIC_GR': aic_gr, 'AIC_IPS': aic_ips,
            'Delta_R2': r_ips**2 - r_gr**2,
            'Delta_AIC': aic_ips - aic_gr,
            'IPS_Win': '✅' if r_ips**2 > r_gr**2 else '❌'
        }

